# ============================================================================
# B-Quant environment configuration
# Copy to `.env` and fill in. NEVER commit `.env`.
#
# Only the BOOTSTRAP section is required to start the stack. All external
# provider keys can instead be pasted into the web UI (Settings -> Providers),
# where they are stored encrypted in the database. If a key is present in both
# places, the database value wins.
# ============================================================================

# ---- BOOTSTRAP (required) --------------------------------------------------
# Secret used for session auth and to encrypt provider keys at rest.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET_KEY=change-me

# Password for the single-user web login.
APP_PASSWORD=change-me

# Inside docker compose these defaults work as-is.
DATABASE_URL=postgresql+psycopg://bquant:bquant@db:5432/bquant
REDIS_URL=redis://redis:6379/0

# ---- ENVIRONMENT -----------------------------------------------------------
# dev | prod. dev enables permissive CORS for the Vite dev server.
APP_ENV=dev
LOG_LEVEL=INFO

# ---- PROVIDER KEYS (optional here — the UI can store these instead) --------
# Alpaca (market data; paper only, never live orders): https://alpaca.markets
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Finnhub (news, fundamentals, calendars): https://finnhub.io
FINNHUB_API_KEY=

# FRED (macro series incl. VIXCLS): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Anthropic (LLM reasoning/triage): https://console.anthropic.com
ANTHROPIC_API_KEY=

# Telegram alerts: create a bot with @BotFather, get your chat id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SEC EDGAR requires a descriptive User-Agent with contact email (SEC policy).
EDGAR_USER_AGENT=B-Quant/0.1 (your-email@example.com)

# ---- TRADING PARAMETERS (initial defaults; editable in Settings UI) --------
STARTING_EQUITY=10000
# Comma-separated initial watchlist
WATCHLIST=SPY,QQQ,NVDA,AAPL,MSFT

# ---- LLM BUDGET ------------------------------------------------------------
# Hard daily token budget; when exceeded, LLM analysts are skipped and
# signals are emitted deterministic-only (flagged as such).
LLM_DAILY_TOKEN_BUDGET=2000000
